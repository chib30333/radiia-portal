# RADIIA Portal — environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`.
#
# Variable set rewritten on 2026-04-24 following the Fantasy API pivot.
# The old FANTASY_OAUTH_* / FANTASY_API_BASE_URL variables are obsolete —
# the portal no longer calls Fantasy's API at runtime.
# See docs/decisions/2026-04-24-fantasy-api-pivot.md.

# --- Database (Phase I) ---
DATABASE_URL=postgresql://user:password@host:5432/radiia?sslmode=require

# --- Auth.js (Phase I) ---
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# --- Email provider (Phase I — default: Resend) ---
RESEND_API_KEY=
# Inbox that receives new-signup notifications and memo / invoice requests.
RADIIA_NOTIFICATION_EMAIL=production@radiia.co

# --- Cron secret (Phase F — FTP ingestion trigger authorization) ---
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Gemstone FTP feed (Phase F) ---
# From Fantasy. Pending — action item from the 2026-04-24 call.
GEMSTONE_FTP_HOST=
GEMSTONE_FTP_USER=
GEMSTONE_FTP_PASSWORD=
GEMSTONE_FTP_PATH=

# --- Skylab FTP feed (Phase D — lab diamonds, post-MVP) ---
# SKYLAB_FTP_HOST=
# SKYLAB_FTP_USER=
# SKYLAB_FTP_PASSWORD=
# SKYLAB_FTP_PATH=

# --- Disons FTP feed (Phase D — natural diamonds, post-MVP) ---
# DISONS_FTP_HOST=
# DISONS_FTP_USER=
# DISONS_FTP_PASSWORD=
# DISONS_FTP_PATH=

# --- Public app URL (used for email links and shareable URLs) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
