generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                      String    @id @default(cuid())
  name                    String
  contactEmail            String?
  contactPhone            String?
  website                 String?
  gemstoneMarkupPct       Decimal   @default(0) @db.Decimal(6, 2)
  labDiamondMarkupPct     Decimal   @default(0) @db.Decimal(6, 2)
  naturalDiamondMarkupPct Decimal   @default(0) @db.Decimal(6, 2)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  users                   User[]
  requests                Request[]
}

enum UserStatus {
  PENDING
  APPROVED
  DECLINED
  DEACTIVATED
}

enum UserRole {
  BUYER
  ADMIN
}

model User {
  id              String               @id @default(cuid())
  email           String               @unique
  passwordHash    String
  fullName        String
  phone           String?
  status          UserStatus           @default(PENDING)
  role            UserRole             @default(BUYER)
  companyId       String?
  company         Company?             @relation(fields: [companyId], references: [id])
  emailVerifiedAt DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  sessions        Session[]
  resetTokens     PasswordResetToken[]
  requests        Request[]

  @@index([companyId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Gemstone {
  id                String   @id @default(cuid())
  feedRowId         String   @unique
  sku               String
  varietyRaw        String?
  shapeRaw          String?
  colorRaw          String?
  weightCt          Decimal? @db.Decimal(10, 3)
  lengthMm          Decimal? @db.Decimal(10, 3)
  widthMm           Decimal? @db.Decimal(10, 3)
  depthMm           Decimal? @db.Decimal(10, 3)
  ratio             Decimal? @db.Decimal(10, 4)
  basePriceUsd      Decimal? @db.Decimal(12, 2)
  basePricePerCtUsd Decimal? @db.Decimal(12, 2)
  certLab           String?
  certNumber        String?
  certUrl           String?
  imageUrl          String?
  image2Url         String?
  image3Url         String?
  image4Url         String?
  videoUrl          String?
  origin            String?
  treatment         String?
  rawFeedRow        Json
  lastSeenAt        DateTime @default(now())
  isAvailable       Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([sku])
  @@index([isAvailable])
  @@index([weightCt])
}

enum RequestType {
  MEMO
  INVOICE
}

enum RequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
}

enum RequestItemStatus {
  PENDING
  APPROVED
  REJECTED
}

model Request {
  id          String        @id @default(cuid())
  type        RequestType
  status      RequestStatus @default(PENDING)
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  note        String?
  submittedAt DateTime      @default(now())
  reviewedAt  DateTime?
  items       RequestItem[]

  @@index([userId])
  @@index([companyId])
  @@index([status])
}

model RequestItem {
  id               String            @id @default(cuid())
  requestId        String
  request          Request           @relation(fields: [requestId], references: [id], onDelete: Cascade)
  gemstoneId       String?
  snapshotSku      String
  snapshotPriceUsd Decimal           @db.Decimal(12, 2)
  snapshotPayload  Json
  status           RequestItemStatus @default(PENDING)

  @@index([requestId])
}
